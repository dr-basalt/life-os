# ─── Domaine ──────────────────────────────────────────────────────────────────
DOMAIN=life-os.example.com
ACME_EMAIL=your@email.com

# ─── PocketBase ───────────────────────────────────────────────────────────────
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change_me_strong_password

# ─── S3 / Litestream (Hetzner Object Storage) ─────────────────────────────────
# Hetzner: endpoint = https://fsn1.your-objectstorage.com
# Backblaze B2: endpoint = https://s3.us-west-001.backblazeb2.com
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=life-os-db
S3_REGION=auto
S3_KEY=your_access_key_id
S3_SECRET=your_secret_access_key

# ─── Windmill ─────────────────────────────────────────────────────────────────
WM_DB_PASS=change_me_windmill_db_pass

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_HOST=172.17.0.1
NEO4J_PASSWORD=SternOS2026xNeo4j

# ─── Claude API (frontend roadmap generation) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SOMA — Agent Runtime (LLM-agnostic) ─────────────────────────────────────
# Gateway OpenAI-compatible : OpenRouter, LiteLLM, Ollama, etc.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
# Modèles recommandés (légers, bons en code) :
#   qwen/qwen-2.5-coder-32b-instruct   (OpenRouter, gratuit)
#   openai/gpt-4o-mini                 (cheap)
#   mistralai/devstral-small           (code focus)
LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct
SOMA_ADMIN_TOKEN=change_me_soma_token
